# Copy this to `.env` to run an ISOLATED instance of the stack from this
# checkout. Both `docker compose` AND `./nemoctl` read this file.
#
# With NO `.env` present, the stack runs as the default PRIVATE instance using
# the original names and ports:
#   nemotron-omni        (vLLM)     -> host port 30030
#   nemotron-harness     (UI)       -> host port 30031
#   nemo-omni-sandbox    (playground)
#   images: nemotron-omni-{vllm,harness,sandbox}
#
# The shared /var/local/shared/nemo-sparky checkout uses a `.env` like the one
# below so it never collides with a private instance on the same Docker daemon.
# (Per-machine coordination: only run ONE instance at a time — the model server
# alone is ~30-35 GB and shares the Spark's unified memory with gary-backend.)

# Compose project name -> isolates the network + compose-managed resources.
COMPOSE_PROJECT_NAME=nemo-shared

# vLLM model server
VLLM_IMAGE=nemo-shared-vllm:local
VLLM_CONTAINER=nemo-shared-omni
VLLM_PORT=30040

# Flask harness UI  ->  open http://localhost:30041
HARNESS_IMAGE=nemo-shared-harness:local
HARNESS_CONTAINER=nemo-shared-harness
HARNESS_PORT=30041

# Sandbox / playground. SANDBOX_IMAGE MUST end in ':current' — nemoctl manages
# the :local baseline, the :current evolving image, and :freeze-* restore points
# under this repository name. This instance's Nemo evolves separately from any
# other instance's Nemo.
SANDBOX_IMAGE=nemo-shared-sandbox:current
SANDBOX_CONTAINER=nemo-shared-sandbox
