#!/usr/bin/env bash
#
# nemoctl — start/stop Nemo's omni stack with a freeze-on-stop, change-logged,
# rollback-able sandbox image, plus an optional periodic auto-freeze that only
# commits when the sandbox's dependencies actually changed (cheap fingerprint,
# like the "skip the backup if the DB is unchanged" trick).
#
#   nemotron-omni-sandbox:local         factory baseline, built from sandbox/Dockerfile
#   nemotron-omni-sandbox:current       evolving image compose runs (frozen on change/stop)
#   nemotron-omni-sandbox:freeze-*      manual restore points (auto-pruned)
#   nemotron-omni-sandbox:freeze-*-auto periodic restore points (auto-pruned)
#
# His DATA lives in the /workspace bind mount (excluded from commits); freezes
# capture tools, never his files. See `nemoctl help`.
set -euo pipefail

SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"
PROJECT_DIR="$(dirname "$SELF")"
cd "$PROJECT_DIR"

SANDBOX_CONTAINER="nemo-omni-sandbox"
IMG="nemotron-omni-sandbox"
IMG_BASE="$IMG:local"
IMG_CURRENT="$IMG:current"

HIST_DIR="$PROJECT_DIR/.sandbox-history"
LOG="$HIST_DIR/freeze-log.md"
APT_MANIFEST="$HIST_DIR/apt.current.txt"
PIP_MANIFEST="$HIST_DIR/pip.current.txt"
FP_FILE="$HIST_DIR/last.fingerprint"
LOCK="$HIST_DIR/.freeze.lock"
WATCH_PID="$HIST_DIR/autofreeze.pid"
WATCH_LOG="$HIST_DIR/autofreeze.log"

KEEP_MANUAL=10
KEEP_AUTO=6
DEFAULT_INTERVAL="${NEMOCTL_FREEZE_INTERVAL:-900}"   # 15 min; only commits on change

mkdir -p "$HIST_DIR"

log()  { printf '\033[1;36m[nemoctl]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[nemoctl]\033[0m %s\n' "$*" >&2; }
die()  { printf '\033[1;31m[nemoctl]\033[0m %s\n' "$*" >&2; exit 1; }
oneline() { tr '\n' ' ' | sed -e 's/[[:space:]]\+/ /g' -e 's/^ //' -e 's/ $//'; }

image_exists()      { docker image inspect "$1" >/dev/null 2>&1; }
container_running() { [ "$(docker inspect -f '{{.State.Running}}' "$SANDBOX_CONTAINER" 2>/dev/null || echo false)" = "true" ]; }
watcher_alive()     { [ -f "$WATCH_PID" ] && kill -0 "$(cat "$WATCH_PID" 2>/dev/null)" 2>/dev/null; }

# Cheap signature of the sandbox's installed-tool state: apt + pip packages plus
# any new/changed files under system dirs (catches tarball-installed binaries
# that no package manager knows about). Hash it; compare across ticks.
compute_fingerprint() {
  container_running || { echo "down"; return 0; }
  # Subshell with errexit/pipefail OFF: a grep that filters everything out
  # returns non-zero, which must not abort the caller (or the watcher daemon).
  ( set +e +o pipefail
    {
      docker exec "$SANDBOX_CONTAINER" dpkg-query -W -f='${Package}=${Version}\n' 2>/dev/null | sort
      docker exec "$SANDBOX_CONTAINER" sh -lc 'pip freeze 2>/dev/null' | sort
      docker diff "$SANDBOX_CONTAINER" 2>/dev/null \
        | grep -E ' (/usr|/opt|/etc|/bin|/sbin|/lib|/srv)' \
        | grep -vE '(/var/log|/var/cache|__pycache__|\.pyc$)' | sort
    } 2>/dev/null | sha256sum | awk '{print $1}'
  )
}

snapshot_manifests_to() {  # $1 = path prefix
  docker exec "$SANDBOX_CONTAINER" dpkg-query -W -f='${Package}\n' 2>/dev/null | sort > "$1.apt" || true
  docker exec "$SANDBOX_CONTAINER" sh -lc 'pip freeze 2>/dev/null || true' | sort > "$1.pip" || true
}

prune_pattern() {  # $1 = grep -E pattern, $2 = keep count
  local i=0 t
  while IFS= read -r t; do
    [ -n "$t" ] || continue
    i=$((i + 1))
    [ "$i" -le "$2" ] || docker rmi "$t" >/dev/null 2>&1 || true
  done < <(docker images --format '{{.Repository}}:{{.Tag}}' "$IMG" | grep -E "$1" | sort -r)
}
prune_freezes() {
  prune_pattern ":freeze-.*-auto$" "$KEEP_AUTO"
  prune_pattern ":freeze-[0-9]{8}-[0-9]{6}$" "$KEEP_MANUAL"
}

build_base() {
  log "Building factory baseline $IMG_BASE from sandbox/Dockerfile…"
  docker build -t "$IMG_BASE" "$PROJECT_DIR/sandbox"
}
ensure_current() {
  if ! image_exists "$IMG_CURRENT"; then
    image_exists "$IMG_BASE" || build_base
    log "No $IMG_CURRENT yet — seeding it from $IMG_BASE."
    docker tag "$IMG_BASE" "$IMG_CURRENT"
  fi
}

# cmd_freeze [auto]  — commit the live sandbox, log the dependency delta, tag a
# restore point, and record the fingerprint. Serialized via flock so a manual
# and an auto freeze can't race.
cmd_freeze() {
  container_running || die "sandbox container not running — nothing to freeze."
  local kind="${1:-manual}" suffix="" mark=""
  [ "$kind" = "auto" ] && { suffix="-auto"; mark=" (auto)"; }

  exec 9>"$LOCK"
  flock -w 60 9 || die "another freeze is in progress."

  local ts tmp; ts="$(date -u +%Y%m%d-%H%M%S)"; tmp="$(mktemp -d)"
  log "Freezing sandbox → $IMG_CURRENT  (freeze-$ts$suffix)$mark…"

  snapshot_manifests_to "$tmp/new"
  local apt_added apt_removed pip_added pip_removed
  if [ -f "$APT_MANIFEST" ]; then
    apt_added="$(comm -13 "$APT_MANIFEST" "$tmp/new.apt" | oneline)"
    apt_removed="$(comm -23 "$APT_MANIFEST" "$tmp/new.apt" | oneline)"
  else
    apt_added="(first freeze — no prior baseline to diff)"; apt_removed=""
  fi
  if [ -f "$PIP_MANIFEST" ]; then
    pip_added="$(comm -13 "$PIP_MANIFEST" "$tmp/new.pip" | oneline)"
    pip_removed="$(comm -23 "$PIP_MANIFEST" "$tmp/new.pip" | oneline)"
  else
    pip_added="(first freeze)"; pip_removed=""
  fi

  local difffile="$HIST_DIR/diff-$ts.txt" fa fc fd
  docker diff "$SANDBOX_CONTAINER" 2>/dev/null \
    | grep -vE '^.\s?(/tmp|/run|/root/\.cache|/var/log|/var/cache|/proc|/sys)' \
    > "$difffile" || true
  fa="$(grep -c '^A' "$difffile" || true)"
  fc="$(grep -c '^C' "$difffile" || true)"
  fd="$(grep -c '^D' "$difffile" || true)"

  docker commit -m "nemoctl freeze $ts$suffix" "$SANDBOX_CONTAINER" "$IMG_CURRENT" >/dev/null
  docker tag "$IMG_CURRENT" "$IMG:freeze-$ts$suffix"

  mv "$tmp/new.apt" "$APT_MANIFEST" 2>/dev/null || true
  mv "$tmp/new.pip" "$PIP_MANIFEST" 2>/dev/null || true
  rm -rf "$tmp"
  compute_fingerprint > "$FP_FILE"

  local size; size="$(docker image inspect -f '{{.Size}}' "$IMG_CURRENT" 2>/dev/null | numfmt --to=iec 2>/dev/null || echo '?')"
  {
    echo "## freeze-$ts$suffix$mark"
    echo "- restore point: \`$IMG:freeze-$ts$suffix\`  (also \`:current\`)   image size: $size"
    echo "- apt added: ${apt_added:-none}"
    [ -n "${apt_removed// }" ] && echo "- apt removed: $apt_removed"
    echo "- pip added: ${pip_added:-none}"
    [ -n "${pip_removed// }" ] && echo "- pip removed: $pip_removed"
    echo "- files: +$fa changed:$fc -$fd   (full delta: .sandbox-history/diff-$ts.txt)"
    echo
  } >> "$LOG"

  prune_freezes
  flock -u 9
  log "Frozen$mark.  apt+: ${apt_added:-none}   logged to ${LOG#"$PROJECT_DIR"/}"
}

# ---- auto-freeze watcher -------------------------------------------------

start_watcher() {
  local interval="$1"
  if watcher_alive; then
    log "Auto-freeze already running (pid $(cat "$WATCH_PID"), every ${interval}s)."
    return
  fi
  setsid bash "$SELF" _watch "$interval" >/dev/null 2>&1 < /dev/null &
  disown 2>/dev/null || true
  sleep 0.3
  watcher_alive && log "Auto-freeze watcher started — checks every ${interval}s, commits only when deps change. Log: ${WATCH_LOG#"$PROJECT_DIR"/}" \
                || warn "auto-freeze watcher failed to start."
}
stop_watcher() {
  if watcher_alive; then
    kill "$(cat "$WATCH_PID")" 2>/dev/null || true
    log "Auto-freeze watcher stopped."
  fi
  rm -f "$WATCH_PID"
}

# internal: the watch loop. Runs detached; commits only on fingerprint change.
cmd__watch() {
  local interval="${1:-$DEFAULT_INTERVAL}"
  # A long-running daemon must not fail-fast on a transient non-zero.
  set +e +o pipefail
  echo $$ > "$WATCH_PID"
  trap 'rm -f "$WATCH_PID"; exit 0' TERM INT EXIT
  printf '[%s] watcher up (interval %ss)\n' "$(date -u +%FT%TZ)" "$interval" >> "$WATCH_LOG"
  while true; do
    sleep "$interval" & wait $! || true
    container_running || { printf '[%s] sandbox down — idle\n' "$(date -u +%FT%TZ)" >> "$WATCH_LOG"; continue; }
    local now stored; now="$(compute_fingerprint)"; stored="$(cat "$FP_FILE" 2>/dev/null || echo none)"
    if [ "$now" = "down" ]; then
      continue
    elif [ "$now" = "$stored" ]; then
      printf '[%s] no dependency change — skipping freeze\n' "$(date -u +%FT%TZ)" >> "$WATCH_LOG"
    else
      printf '[%s] change detected — freezing\n' "$(date -u +%FT%TZ)" >> "$WATCH_LOG"
      cmd_freeze auto >> "$WATCH_LOG" 2>&1 || printf '[%s] freeze error\n' "$(date -u +%FT%TZ)" >> "$WATCH_LOG"
    fi
  done
}

# ---- top-level commands --------------------------------------------------

cmd_up() {
  local interval="$DEFAULT_INTERVAL" want_watch=1 svcs=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --no-watch)          want_watch=0 ;;
      --interval) shift;   interval="${1:?--interval needs seconds}" ;;
      --interval=*)        interval="${1#*=}" ;;
      *)                   svcs+=("$1") ;;
    esac
    shift
  done
  ensure_current
  log "Starting the omni network…"
  docker compose up -d "${svcs[@]}"
  [ "$want_watch" = 1 ] && start_watcher "$interval" || log "Auto-freeze disabled (--no-watch)."
  log "Up.  Harness → http://localhost:30031   (vLLM warms in ~3 min)"
  log "Watch the model:  docker compose logs -f nemotron-omni"
}

cmd_down() {
  stop_watcher
  if container_running; then cmd_freeze manual; else warn "sandbox not running — skipping freeze."; fi
  log "Stopping the omni network…"
  docker compose down
  log "Down.  Baseline $IMG_BASE and frozen $IMG_CURRENT remain on disk."
}

cmd_watch()   { container_running || warn "sandbox isn't running yet."; start_watcher "${1:-$DEFAULT_INTERVAL}"; }
cmd_unwatch() { stop_watcher; }

cmd_rollback() {
  local target="${1:-}" tag
  [ -n "$target" ] || { cmd_history; die "usage: nemoctl rollback <freeze-YYYYmmdd-HHMMSS[-auto]>"; }
  case "$target" in
    *:*)       tag="$target" ;;
    freeze-*)  tag="$IMG:$target" ;;
    *)         tag="$IMG:freeze-$target" ;;
  esac
  image_exists "$tag" || die "no such restore point: $tag   (try: nemoctl history)"
  ! container_running || die "network is up. Run 'nemoctl down' first (it freezes the current state so this rollback is non-destructive), then roll back."
  docker tag "$tag" "$IMG_CURRENT"
  echo "## rollback $(date -u +%Y%m%d-%H%M%S) — :current set to $tag" >> "$LOG"
  log "Rolled :current back to $tag.  Run 'nemoctl up' to start from it."
}

cmd_reset() {
  ! container_running || die "network is up — run 'nemoctl down' first."
  if [ "${1:-}" != "-y" ]; then
    warn "This rebuilds the baseline from sandbox/Dockerfile and resets :current to it."
    read -rp "Wipe Nemo's evolved image back to factory? His /workspace is untouched. [y/N] " a
    [ "$a" = "y" ] || [ "$a" = "Y" ] || die "aborted."
  fi
  build_base
  docker tag "$IMG_BASE" "$IMG_CURRENT"
  rm -f "$APT_MANIFEST" "$PIP_MANIFEST" "$FP_FILE"
  echo "## reset $(date -u +%Y%m%d-%H%M%S) — :current reset to fresh Dockerfile baseline" >> "$LOG"
  log "Reset done. :current is now the factory baseline. /workspace (his data) untouched."
}

cmd_status() {
  log "Containers:"
  docker compose ps --format 'table {{.Name}}\t{{.Status}}' 2>/dev/null || true
  echo
  if watcher_alive; then log "Auto-freeze: ON (pid $(cat "$WATCH_PID"))"; else log "Auto-freeze: off"; fi
  echo
  log "Sandbox images:"
  docker images --format ' {{.Repository}}:{{.Tag}}\t{{.Size}}\t{{.CreatedSince}}' "$IMG" \
    | grep -E ':(current|local|freeze-)' | sort || echo "  (none yet — run nemoctl up)"
}

cmd_history() {
  log "Freeze log → ${LOG#"$PROJECT_DIR"/}"
  if [ -f "$LOG" ]; then tail -n 50 "$LOG"; else echo "  (no freezes yet)"; fi
  echo
  log "Restore points for 'nemoctl rollback':"
  docker images --format ' {{.Repository}}:{{.Tag}}\t{{.Size}}\t{{.CreatedSince}}' "$IMG" \
    | grep ':freeze-' | sort -r || echo "  (none yet)"
}

cmd_help() {
  cat <<'EOF'
nemoctl — manage Nemo's omni stack with a freeze-on-stop sandbox image.

  nemoctl up [--no-watch] [--interval N] [svc...]
                         Seed :current if needed, compose up -d, and start the
                         periodic auto-freeze (every N seconds, default 900).
  nemoctl down           Stop auto-freeze, FREEZE the sandbox, then compose down.
  nemoctl freeze         Freeze now (manual checkpoint) without stopping.
  nemoctl watch [N]      Start auto-freeze on an already-running stack.
  nemoctl unwatch        Stop the auto-freeze watcher only.
  nemoctl status         Containers, auto-freeze state, sandbox image tags.
  nemoctl history        Recent freeze changelog + rollback restore points.
  nemoctl rollback <ts>  Point :current at a freeze-<ts> restore point (down first).
  nemoctl reset [-y]     Rebuild factory baseline and reset :current to it.
  nemoctl build-base     (Re)build the Dockerfile baseline image :local.

Auto-freeze only commits when the sandbox's dependencies actually change
(apt/pip packages or new files under system dirs) — idle time costs nothing.
Heartbeat + skips are logged to .sandbox-history/autofreeze.log.
Tools Nemo installs persist in :current; his files live in /workspace and
persist regardless. Don't `docker compose build sandbox` — use `nemoctl reset`.
EOF
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  up)          cmd_up "$@" ;;
  down|stop)   cmd_down ;;
  freeze)      cmd_freeze "${1:-manual}" ;;
  watch)       cmd_watch "$@" ;;
  unwatch)     cmd_unwatch ;;
  _watch)      cmd__watch "$@" ;;
  status)      cmd_status ;;
  history|log) cmd_history ;;
  rollback)    cmd_rollback "$@" ;;
  reset)       cmd_reset "$@" ;;
  build-base)  build_base ;;
  help|-h|--help) cmd_help ;;
  *) warn "unknown command: $cmd"; cmd_help; exit 1 ;;
esac
